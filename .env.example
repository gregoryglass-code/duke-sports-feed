# Required: Claude API key for article clustering and summarization
ANTHROPIC_API_KEY=sk-ant-api03-...

# Optional (but required for production): Upstash Redis for shared caching
# Without these, the app uses in-memory caching only — works for dev but
# causes "Story not found" errors under load on Vercel.
KV_REST_API_URL=https://your-instance.upstash.io
KV_REST_API_TOKEN=your-token-here
